# Host path to editions directory (mounted read-only into corre-news container)
# CORRE_EDITIONS_DIR=~/.local/share/corre/editions

# Tailscale (optional — set TAILSCALE_ENABLED=true to activate)
# TAILSCALE_ENABLED=true
# TAILSCALE_AUTHKEY="tskey-auth-..."
# TS_HOSTNAME=corre
#
# When enabled, services are available at:
#   Dashboard:  https://<TS_HOSTNAME>.<tailnet>.ts.net/
#   CorreNews:  https://<TS_HOSTNAME>.<tailnet>.ts.net:8443/
#
# Prerequisites:
#   - Enable MagicDNS in the Tailscale admin console
#   - Enable HTTPS certificates in the Tailscale admin DNS settings