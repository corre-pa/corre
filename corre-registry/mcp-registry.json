      "name": "Kagi Search",
      "description": "Search and summarization via the Kagi API",
      "version": "0.1.3",
      "install": {
        "method": "pip",
        "package": "kagimcp",
        "command": "uvx",
        "args": [
          "kagimcp"
        ]
      },
      "config": [
        {
          "name": "KAGI_API_KEY",
          "description": "Kagi API key (https://www.kagi.com/account/api)",
