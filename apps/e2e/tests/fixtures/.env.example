# Copy to apps/e2e/tests/fixtures/.env and fill in your real values.
# These are read by tests/e2e-corre-gym.rs at startup via dotenvy.

CORRE_TEST_LLM_BASE_URL=https://api.venice.ai/api/v1
CORRE_TEST_LLM_MODEL=nvidia-nemotron-3-nano-30b-a3b
CORRE_TEST_LLM_API_KEY=sk-...

# Logging filter. Overrides the runner default of "info,corre_gym=debug,e2e=debug".
RUST_LOG=info,corre_gym=debug,e2e=debug
